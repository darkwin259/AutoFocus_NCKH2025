#ifndef __MS41929_H
#define __MS41929_H

#include "main.h"

// --- ĐỊA CHỈ THANH GHI (Theo Datasheet MS41929) ---
#define MS_REG_PWM          0x20
#define MS_REG_PHASE_AB     0x22
#define MS_REG_CUR_AB       0x23
#define MS_REG_STEP_AB      0x24  // Điều khiển Motor AB và LED 2 (LEDB)
#define MS_REG_INTCT_AB     0x25

#define MS_REG_PHASE_CD     0x27
#define MS_REG_CUR_CD       0x28
#define MS_REG_STEP_CD      0x29  // Điều khiển Motor CD và LED 1 (LEDA)
#define MS_REG_INTCT_CD     0x2A

#define MS_REG_LED_CTRL     0x2B
#define MS_REG_DIRECTION    0x2C

// --- CÁC HÀM GIAO TIẾP ---
void MS41929_Init(void);
void MS41929_WriteReg(uint8_t addr, uint16_t data);
void MS41929_SetDirection(uint8_t dir);
void MS41929_Step(uint16_t count);
void MS41929_ControlLED(uint8_t led1_state, uint8_t led2_state);

#endif
