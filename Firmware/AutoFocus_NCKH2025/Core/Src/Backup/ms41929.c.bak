#include "ms41929.h"

extern SPI_HandleTypeDef hspi1;

// Biến toàn cục lưu trạng thái thanh ghi (Shadow Registers)
// 0x080F: Bit 11=1 (Enable Motor), Bit[7:0]=0x0F (15 microsteps/xung)
uint16_t reg_step_ab_shadow = 0x080F;
uint16_t reg_step_cd_shadow = 0x080F;

// Gửi 24-bit: 8-bit Addr + 16-bit Data (Chuẩn LSB First)
void MS41929_WriteReg(uint8_t addr, uint16_t data) {
    uint8_t pData[3];
    pData[0] = (addr & 0x3F); // Header: 6-bit addr, R/W=0, C1=0
    pData[1] = (uint8_t)(data & 0xFF);
    pData[2] = (uint8_t)((data >> 8) & 0xFF);

    // Kéo CS xuống Thấp để chốt chọn Chip
    HAL_GPIO_WritePin(MS_CS_GPIO_Port, MS_CS_Pin, GPIO_PIN_RESET);

    // Gửi 24 bit qua SPI
    HAL_SPI_Transmit(&hspi1, pData, 3, HAL_MAX_DELAY);

    // Kéo CS lên Cao để kết thúc
    HAL_GPIO_WritePin(MS_CS_GPIO_Port, MS_CS_Pin, GPIO_PIN_SET);

    // Delay nhỏ giọt để IC kịp Latch (lưu) dữ liệu vào bộ nhớ
    for(volatile int delay = 0; delay < 50; delay++);
}

void MS41929_Init(void) {
    // 1. Hardware Reset (Reset cứng bảo vệ IC)
    HAL_GPIO_WritePin(MS_RSTB_GPIO_Port, MS_RSTB_Pin, GPIO_PIN_RESET);
    HAL_Delay(10);
    HAL_GPIO_WritePin(MS_RSTB_GPIO_Port, MS_RSTB_Pin, GPIO_PIN_SET);
    HAL_Delay(10);

    // 2. Cấu hình các thanh ghi cốt lõi
    MS41929_WriteReg(MS_REG_PWM, 0x1E03);      // 112.5kHz PWM
    MS41929_WriteReg(MS_REG_PHASE_AB, 0x0002); // Chỉnh lệch pha 90 độ
    MS41929_WriteReg(MS_REG_CUR_AB, 0x7878);   // Dòng điện giới hạn 50%

    // 3. Nạp trạng thái Enable Motor từ Shadow Register
    MS41929_WriteReg(MS_REG_STEP_AB, reg_step_ab_shadow);
    MS41929_WriteReg(MS_REG_STEP_CD, reg_step_cd_shadow);
    MS41929_WriteReg(MS_REG_INTCT_AB, 0x1AB5); // Cấu hình tốc độ
}

void MS41929_SetDirection(uint8_t dir) {
    // Bit 0 của Reg 2CH điều khiển hướng Motor A-B
    if(dir) MS41929_WriteReg(MS_REG_DIRECTION, 0x0001);
    else    MS41929_WriteReg(MS_REG_DIRECTION, 0x0000);
}

void MS41929_Step(uint16_t count) {
    for(uint16_t i=0; i<count; i++) {
        // Vì PB0 đang ở chế độ AF_PP (Timer), ta cần dùng thanh ghi trực tiếp
        // hoặc tạm thời cấu hình lại chân này là Output trong STM32CubeIDE
        // để dùng HAL_GPIO_WritePin.

        HAL_GPIO_WritePin(VD_FZ_GPIO_Port, VD_FZ_Pin, GPIO_PIN_SET);
        for(volatile int d=0; d<20; d++); // Pulse width ~5us
        HAL_GPIO_WritePin(VD_FZ_GPIO_Port, VD_FZ_Pin, GPIO_PIN_RESET);

        // Tốc độ: 1ms mỗi xung (Dễ soi trên Oscillo)
        HAL_Delay(1);
    }
}

/**
  * @brief  Điều khiển LED1 và LED2 độc lập (Dùng cho test SPI)
  * @param  led1_state: 1 (Sáng), 0 (Tắt)
  * @param  led2_state: 1 (Sáng), 0 (Tắt)
  */
void MS41929_ControlLED(uint8_t led1_state, uint8_t led2_state) {
    // LED1 (LEDA) nằm ở Bit 12 của thanh ghi 0x29
    if(led1_state) reg_step_cd_shadow |= (1 << 12);
    else           reg_step_cd_shadow &= ~(1 << 12);

    // LED2 (LEDB) nằm ở Bit 12 của thanh ghi 0x24
    if(led2_state) reg_step_ab_shadow |= (1 << 12);
    else           reg_step_ab_shadow &= ~(1 << 12);

    MS41929_WriteReg(MS_REG_STEP_CD, reg_step_cd_shadow);
    MS41929_WriteReg(MS_REG_STEP_AB, reg_step_ab_shadow);
}
