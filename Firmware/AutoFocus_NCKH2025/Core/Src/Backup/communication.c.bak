#include "communication.h"
#include <string.h>

extern UART_HandleTypeDef huart1;
uint8_t rx_data[8];
uint8_t cmd_buffer[8];
volatile uint8_t cmd_ready = 0;

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
    if(huart->Instance == USART1) {
        // 1. Kiểm tra nhanh (Header, Tail, Checksum)
        if(rx_data[0] == 0xAA && rx_data[7] == 0x55) {
            uint8_t calc_sum = rx_data[1] ^ rx_data[2] ^ rx_data[3] ^ rx_data[4] ^ rx_data[5];
            if(calc_sum == rx_data[6]) {
                // 2. Nếu ĐÚNG: Copy dữ liệu và DỰNG CỜ
                memcpy(cmd_buffer, rx_data, 8);
                cmd_ready = 1;
            }
        }
        // 3. Khởi động lại DMA ngay lập tức để chờ gói tin tiếp theo
        HAL_UART_Receive_DMA(&huart1, rx_data, 8);
    }
}

// Hàm này bây giờ chỉ làm nhiệm vụ giải mã (Parsing)
uint8_t Execute_Command(uint8_t *data) {
    uint8_t command = data[2];
    uint8_t direction = data[3];
    uint16_t steps = (uint16_t)((data[4] << 8) | data[5]);

    switch(command) {
        case 0x01: // Move focus
            MS41929_SetDirection(direction);
            MS41929_Step(steps);
            break;
        case 0x04: // Hardware Reset IC Motor
            HAL_GPIO_WritePin(MS_RSTB_GPIO_Port, MS_RSTB_Pin, GPIO_PIN_RESET);
            HAL_Delay(10);
            HAL_GPIO_WritePin(MS_RSTB_GPIO_Port, MS_RSTB_Pin, GPIO_PIN_SET);
            break;
        default: return 0;
    }
    return 1;
}
